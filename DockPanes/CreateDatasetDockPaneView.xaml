<UserControl x:Class="ArcGisProAppYolo.DockPanes.CreateDatasetDockPaneView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:res="clr-namespace:ArcGisProAppYolo.Resources"
             mc:Ignorable="d"
             d:DesignHeight="900"
             d:DesignWidth="450">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/ArcGIS.Desktop.Framework;component/Themes/Default.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

            <CollectionViewSource x:Key="EnabledPreviewOperationsView"
                                  Source="{Binding EnabledPreviewOperations}">
                <CollectionViewSource.GroupDescriptions>
                    <PropertyGroupDescription PropertyName="Category" />
                </CollectionViewSource.GroupDescriptions>
            </CollectionViewSource>

            <DataTemplate x:Key="AugmentationTemplate">
                <Border Margin="0,0,0,8" Padding="6" BorderBrush="#22000000" BorderThickness="1" CornerRadius="4">
                    <StackPanel>
                        <CheckBox Content="{Binding Name}" IsChecked="{Binding IsEnabled}" ToolTip="{x:Static res:Strings.Dataset_AugmentationEnableTooltip}" />

                        <TextBlock Margin="0,4,0,0"
                                   Text="{Binding Description}"
                                   Foreground="#555"
                                   TextWrapping="Wrap" />
                        <TextBlock Margin="0,2,0,0"
                                   Text="{Binding Recommendation, StringFormat={x:Static res:Strings.Dataset_RecommendationFormat}}"
                                   Foreground="#2F6F9F"
                                   FontStyle="Italic"
                                   TextWrapping="Wrap" />

                        <Grid Margin="0,6,0,0" Visibility="{Binding ShowValueSlider, Converter={StaticResource BoolToVisibility}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="76" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="76" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="18" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{x:Static res:Strings.Dataset_Range}" />
                            <TextBox Grid.Column="1"
                                     Margin="8,0,0,0"
                                     Text="{Binding ValueMinText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="{x:Static res:Strings.Dataset_RangeLowerTooltip}" />
                            <Button Grid.Column="2" Margin="2,0,0,0" Padding="0" Content="-" Command="{Binding DecrementValueMinCommand}" ToolTip="{x:Static res:Strings.Dataset_DecrementLowerTooltip}" />
                            <Button Grid.Column="3" Margin="2,0,0,0" Padding="0" Content="+" Command="{Binding IncrementValueMinCommand}" ToolTip="{x:Static res:Strings.Dataset_IncrementLowerTooltip}" />

                            <TextBox Grid.Column="5"
                                     Margin="8,0,0,0"
                                     Text="{Binding ValueMaxText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="{x:Static res:Strings.Dataset_RangeUpperTooltip}" />
                            <Button Grid.Column="6" Margin="2,0,0,0" Padding="0" Content="-" Command="{Binding DecrementValueMaxCommand}" ToolTip="{x:Static res:Strings.Dataset_DecrementUpperTooltip}" />
                            <Button Grid.Column="7" Margin="2,0,0,0" Padding="0" Content="+" Command="{Binding IncrementValueMaxCommand}" ToolTip="{x:Static res:Strings.Dataset_IncrementUpperTooltip}" />
                        </Grid>

                        <Grid Margin="0,4,0,0" Visibility="{Binding ShowProbabilitySlider, Converter={StaticResource BoolToVisibility}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="76" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{x:Static res:Strings.Dataset_Probability}" />
                            <TextBox Grid.Column="1"
                                     Margin="8,0,0,0"
                                     Text="{Binding ProbabilityText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="{x:Static res:Strings.Dataset_ProbabilityTooltip}" />
                            <Button Grid.Column="2" Margin="2,0,0,0" Padding="0" Content="-" Command="{Binding DecrementProbabilityCommand}" ToolTip="{x:Static res:Strings.Dataset_DecrementProbTooltip}" />
                            <Button Grid.Column="3" Margin="2,0,0,0" Padding="0" Content="+" Command="{Binding IncrementProbabilityCommand}" ToolTip="{x:Static res:Strings.Dataset_IncrementProbTooltip}" />
                            <TextBlock Grid.Column="4"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="#666"
                                       Text="{Binding MinProbability, StringFormat=min: {0:0.##}}"
                                       ToolTip="{x:Static res:Strings.Dataset_MinProbTooltip}" />
                            <TextBlock Grid.Column="5"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="#666"
                                       Text="{Binding MaxProbability, StringFormat=max: {0:0.##}}"
                                       ToolTip="{x:Static res:Strings.Dataset_MaxProbTooltip}" />
                        </Grid>

                        <Button Content="{x:Static res:Strings.Common_Reset}"
                                Margin="0,6,0,0"
                                Width="90"
                                HorizontalAlignment="Left"
                                Command="{Binding DataContext.ResetAugmentationCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}"
                                ToolTip="{x:Static res:Strings.Dataset_ResetTooltip}" />
                    </StackPanel>
                </Border>
            </DataTemplate>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="10">
            <GroupBox Header="{x:Static res:Strings.Dataset_OrthoSelection}" Margin="0,0,0,10">
                <StackPanel Margin="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0"
                                  ItemsSource="{Binding OrthoList}"
                                  SelectedItem="{Binding SelectedOrtho}"
                                  Margin="0,0,6,0"
                                  ToolTip="{x:Static res:Strings.Dataset_OrthoTooltip}" />
                        <Button Grid.Column="1"
                                Content="⟳"
                                Width="28"
                                Height="28"
                                Command="{Binding RefreshOrthoListCommand}"
                                ToolTip="{x:Static res:Strings.Dataset_RefreshOrthoTooltip}" />
                    </Grid>
                    <TextBlock Margin="0,4,0,0" Foreground="Gray" Text="{Binding OrthoList.Count, StringFormat={x:Static res:Strings.Dataset_AvailableFormat}}" />
                </StackPanel>
            </GroupBox>

            <GroupBox Header="{x:Static res:Strings.Dataset_AnnotationLayers}" Margin="0,0,0,10">
                <StackPanel Margin="6">
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Text="{x:Static res:Strings.Dataset_AnnotationLayersFilter}"
                                   TextWrapping="Wrap"
                                   Foreground="#555"
                                   ToolTip="{x:Static res:Strings.Dataset_AnnotationLayersFilterTooltip}" />
                        <Button Grid.Column="1"
                                Content="⟳"
                                Width="28"
                                Height="28"
                                Margin="8,0,0,0"
                                Command="{Binding RefreshAnnotationLayersCommand}"
                                ToolTip="{x:Static res:Strings.Dataset_RefreshAnnotationTooltip}" />
                    </Grid>

                    <Border BorderBrush="#22000000" BorderThickness="1" CornerRadius="4" Padding="6">
                        <ScrollViewer MaxHeight="120" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding AnnotationLayers}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}" Margin="0,0,0,4" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <TextBlock Margin="0,6,0,0" Foreground="#666" Text="{Binding SelectedAnnotationLayersSummary}" />
                </StackPanel>
            </GroupBox>

            <GroupBox Header="{x:Static res:Strings.Dataset_SlicingParameters}" Margin="0,0,0,10">
                <StackPanel Margin="6">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Width="140" VerticalAlignment="Center" Text="{x:Static res:Strings.Dataset_TileSizePx}" />
                        <TextBox Width="100" Text="{Binding TileSize, UpdateSourceTrigger=PropertyChanged}" ToolTip="{x:Static res:Strings.Dataset_TileSizeTooltip}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Width="140" VerticalAlignment="Center" Text="{x:Static res:Strings.Dataset_Overlap}" />
                        <TextBox Width="100" Text="{Binding Overlap, UpdateSourceTrigger=PropertyChanged}" ToolTip="{x:Static res:Strings.Dataset_OverlapTooltip}" />
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="{x:Static res:Strings.Dataset_DatasetType}" Margin="0,0,0,10">
                <StackPanel Margin="6">
                    <ComboBox Margin="0,6,0,0" ItemsSource="{Binding DatasetTypes}" SelectedItem="{Binding SelectedDatasetType}" ToolTip="{x:Static res:Strings.Dataset_DatasetTypeTooltip}" />
                </StackPanel>
            </GroupBox>

            <GroupBox Header="{x:Static res:Strings.Dataset_SplitHeader}" Margin="0,0,0,10">
                <StackPanel Margin="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="20" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Train:" />
                        <TextBox Grid.Column="1" Text="{Binding TrainPercent, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="%" />
                    </Grid>
                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="20" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Val:" />
                        <TextBox Grid.Column="1" Text="{Binding ValPercent, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="%" />
                    </Grid>
                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="20" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Test:" />
                        <TextBox Grid.Column="1" Text="{Binding TestPercent, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="%" />
                    </Grid>
                    <TextBlock Margin="0,6,0,0" Text="{Binding SplitSummary}" Foreground="#666" />
                    <TextBlock Margin="0,4,0,0" Text="{Binding SplitWarning}" Foreground="#c97b00" TextWrapping="Wrap" />
                </StackPanel>
            </GroupBox>

            <GroupBox Header="{x:Static res:Strings.Dataset_BackgroundHeader}" Margin="0,0,0,10">
                <StackPanel Margin="6">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Width="180" VerticalAlignment="Center" Text="{x:Static res:Strings.Dataset_BackgroundLimit}" />
                        <TextBox Width="70" Text="{Binding BackgroundLimit, UpdateSourceTrigger=PropertyChanged}" />
                        <CheckBox Margin="10,0,0,0" VerticalAlignment="Center" Content="{x:Static res:Strings.Dataset_Percent}" IsChecked="{Binding BackgroundLimitIsPercent}" />
                    </StackPanel>

                    <CheckBox Content="{x:Static res:Strings.Dataset_EnableClassBalancing}" IsChecked="{Binding EnableClassBalancing}" ToolTip="{x:Static res:Strings.Dataset_EnableClassBalancingTooltip}" />
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock Width="180" VerticalAlignment="Center" Text="{x:Static res:Strings.Dataset_BalancingMethod}" />
                        <ComboBox Width="140" ItemsSource="{Binding BalanceMethods}" SelectedItem="{Binding SelectedBalanceMethod}" />
                    </StackPanel>

                    <CheckBox Margin="0,8,0,0" Content="{x:Static res:Strings.Dataset_DebugMode}" IsChecked="{Binding DebugMode}" ToolTip="{x:Static res:Strings.Dataset_DebugModeTooltip}" />
                </StackPanel>
            </GroupBox>

            <Expander Header="{x:Static res:Strings.Dataset_DataAugmentation}" IsExpanded="{Binding IsAugmentationExpanded}" Margin="0,0,0,10">
                <StackPanel Margin="6">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock VerticalAlignment="Center" Text="{x:Static res:Strings.Dataset_Seed}" Width="60" />
                        <TextBox Width="120" Text="{Binding Seed, UpdateSourceTrigger=PropertyChanged}" ToolTip="{x:Static res:Strings.Dataset_SeedTooltip}" />
                        <CheckBox Margin="12,0,0,0"
                                  VerticalAlignment="Center"
                                  Content="{x:Static res:Strings.Dataset_ApplyToVal}"
                                  IsChecked="{Binding ApplyToVal}"
                                  ToolTip="{x:Static res:Strings.Dataset_ApplyToValTooltip}" />
                        <CheckBox Margin="8,0,0,0"
                                  VerticalAlignment="Center"
                                  Content="{x:Static res:Strings.Dataset_ApplyToTest}"
                                  IsChecked="{Binding ApplyToTest}"
                                  ToolTip="{x:Static res:Strings.Dataset_ApplyToTestTooltip}" />
                    </StackPanel>

                    <TabControl>
                        <TabItem Header="{x:Static res:Strings.Dataset_TabGeometry}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding GeometryAugmentations}" ItemTemplate="{StaticResource AugmentationTemplate}" />
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="{x:Static res:Strings.Dataset_TabColor}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding ColorAugmentations}" ItemTemplate="{StaticResource AugmentationTemplate}" />
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="{x:Static res:Strings.Dataset_TabNoiseBlur}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding NoiseAugmentations}" ItemTemplate="{StaticResource AugmentationTemplate}" />
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="{x:Static res:Strings.Dataset_TabAdvanced}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding AdvancedAugmentations}" ItemTemplate="{StaticResource AugmentationTemplate}" />
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="{x:Static res:Strings.Dataset_TabPreview}">
                            <StackPanel Margin="6">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Width="120" VerticalAlignment="Center" Text="{x:Static res:Strings.Dataset_TilesFolder}" />
                                    <TextBox Width="220" Text="{Binding PreviewTilesFolder, UpdateSourceTrigger=PropertyChanged}" ToolTip="{x:Static res:Strings.Dataset_TilesFolderTooltip}" />
                                    <Button Margin="8,0,0,0" Content="{x:Static res:Strings.Common_Browse}" Command="{Binding BrowsePreviewTilesFolderCommand}" ToolTip="{x:Static res:Strings.Dataset_BrowsePreviewTooltip}" />
                                    <Button Margin="8,0,0,0"
                                            Content="{x:Static res:Strings.Dataset_ApplyNextTransform}"
                                            Command="{Binding ApplyRandomPreviewCommand}"
                                            ToolTip="{x:Static res:Strings.Dataset_ApplyNextTransformTooltip}" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Width="120" VerticalAlignment="Center" Text="{x:Static res:Strings.Dataset_ApplySelected}" />
                                    <ComboBox Width="220"
                                              ItemsSource="{Binding Source={StaticResource EnabledPreviewOperationsView}}"
                                              DisplayMemberPath="DisplayName"
                                              SelectedItem="{Binding SelectedPreviewOperation, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              ToolTip="{x:Static res:Strings.Dataset_ApplySelectedTooltip}">
                                        <ComboBox.GroupStyle>
                                            <GroupStyle>
                                                <GroupStyle.HeaderTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="#666" />
                                                    </DataTemplate>
                                                </GroupStyle.HeaderTemplate>
                                            </GroupStyle>
                                        </ComboBox.GroupStyle>
                                    </ComboBox>
                                  <TextBlock VerticalAlignment="Center"
                                           Foreground="#2F6F9F"
                                           FontStyle="Italic"
                                           Text="{x:Static res:Strings.Dataset_ApplyingTransform}"
                                           Visibility="{Binding IsPreviewApplying, Converter={StaticResource BoolToVisibility}}" />
                                </StackPanel>

                                

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Width="120" VerticalAlignment="Center" Text="{x:Static res:Strings.Dataset_CurrentTile}" />
                                    <TextBox Width="220" Text="{Binding PreviewTile, UpdateSourceTrigger=PropertyChanged}" ToolTip="{x:Static res:Strings.Dataset_CurrentTileTooltip}" />
                                    <Button Margin="8,0,0,0" Width="28" Content="←" Command="{Binding PreviewPrevImageCommand}" ToolTip="{x:Static res:Strings.Dataset_PrevImageTooltip}" />
                                    <TextBlock Margin="8,0,8,0" Width="70" VerticalAlignment="Center" TextAlignment="Center" Text="{Binding PreviewImagePosition}" />
                                    <Button Width="28" Content="→" Command="{Binding PreviewNextImageCommand}" ToolTip="{x:Static res:Strings.Dataset_NextImageTooltip}" />
                                </StackPanel>

                                <TextBlock Margin="0,0,0,8"
                                           Foreground="#555"
                                           TextWrapping="Wrap"
                                           Text="{x:Static res:Strings.Dataset_PreviewInstructions}" />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Margin="0,0,6,0" Height="180" BorderThickness="1" BorderBrush="#33000000" Background="#11000000">
                                        <Image Stretch="Uniform" Source="{Binding OriginalPreviewImagePath}" />
                                    </Border>
                                    <Border Grid.Column="1" Margin="6,0,0,0" Height="180" BorderThickness="1" BorderBrush="#33000000" Background="#11000000">
                                        <Image Stretch="Uniform" Source="{Binding AugmentedPreviewImagePath}" />
                                    </Border>
                                </Grid>

                                <TextBlock Margin="0,8,0,0" Text="{x:Static res:Strings.Dataset_Applied}" FontWeight="Bold" />
                                <TextBlock Text="{Binding PreviewAppliedTransforms}" TextWrapping="Wrap" />
                            </StackPanel>
                        </TabItem>

                        <TabItem Header="{x:Static res:Strings.Dataset_TabPresets}">
                            <StackPanel Margin="6">
                                <TextBlock Text="{x:Static res:Strings.Dataset_BuiltInPresets}" FontWeight="Bold" />
                                <TextBlock Margin="0,4,0,0"
                                           Foreground="#555"
                                           TextWrapping="Wrap"
                                           Text="{x:Static res:Strings.Dataset_PresetsDescription}" />
                                <WrapPanel Margin="0,6,0,0">
                                    <Button Margin="0,0,6,6" Content="None" Command="{Binding ApplyPresetCommand}" CommandParameter="None" ToolTip="{x:Static res:Strings.Dataset_PresetNoneTooltip}" />
                                    <Button Margin="0,0,6,6" Content="Light" Command="{Binding ApplyPresetCommand}" CommandParameter="Light" ToolTip="{x:Static res:Strings.Dataset_PresetLightTooltip}" />
                                    <Button Margin="0,0,6,6" Content="Standard" Command="{Binding ApplyPresetCommand}" CommandParameter="Standard" ToolTip="{x:Static res:Strings.Dataset_PresetStandardTooltip}" />
                                    <Button Margin="0,0,6,6" Content="Aggressive" Command="{Binding ApplyPresetCommand}" CommandParameter="Aggressive" ToolTip="{x:Static res:Strings.Dataset_PresetAggressiveTooltip}" />
                                    <Button Margin="0,0,6,6" Content="Outdoor Aerial" Command="{Binding ApplyPresetCommand}" CommandParameter="Outdoor Aerial" ToolTip="{x:Static res:Strings.Dataset_PresetOutdoorAerialTooltip}" />
                                </WrapPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <Button Content="{x:Static res:Strings.Dataset_SavePreset}"
                                            Command="{Binding SavePresetCommand}"
                                            Margin="0,0,6,0"
                                            ToolTip="{x:Static res:Strings.Dataset_SavePresetTooltip}" />
                                    <Button Content="{x:Static res:Strings.Dataset_LoadPreset}"
                                            Command="{Binding LoadPresetCommand}"
                                            ToolTip="{x:Static res:Strings.Dataset_LoadPresetTooltip}" />
                                </StackPanel>

                                <Button Margin="0,8,0,0"
                                        Content="{x:Static res:Strings.Dataset_ExportHyp}"
                                        Command="{Binding ExportHypCommand}"
                                        Width="160"
                                        ToolTip="{x:Static res:Strings.Dataset_ExportHypTooltip}" />
                            </StackPanel>
                        </TabItem>
                    </TabControl>

                    <GroupBox Header="{x:Static res:Strings.Dataset_Summary}" Margin="0,10,0,0">
                        <StackPanel Margin="6">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Width="210" VerticalAlignment="Center" Text="{x:Static res:Strings.Dataset_EstimatedSourceImages}" />
                                <TextBox Width="100" Text="{Binding EstimatedSourceTiles, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <TextBlock Text="{Binding DatasetMultiplier, StringFormat={x:Static res:Strings.Dataset_DatasetMultiplierFormat}}" />
                            <TextBlock Margin="0,4,0,0" Text="{Binding EstimatedTotalAfterAugmentation, StringFormat={x:Static res:Strings.Dataset_EstimatedTotalFormat}}" />
                            <TextBlock Margin="0,4,0,0" Text="{Binding EstimatedGenerationTime, StringFormat={x:Static res:Strings.Dataset_EstimatedTimeFormat}}" />
                            <TextBlock Margin="0,4,0,0" Foreground="#c97b00" TextWrapping="Wrap" Text="{Binding DatasetSizeWarning}" />
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </Expander>

            <TextBlock Margin="0,0,0,8" Foreground="#c97b00" TextWrapping="Wrap" Text="{Binding ValidationWarning}" />

            <Button Height="32"
                    Content="{Binding RunButtonText}"
                    Command="{Binding RunCreateDatasetCommand}"
                    IsEnabled="{Binding IsRunEnabled}"
                    ToolTip="{x:Static res:Strings.Dataset_RunTooltip}" />

            <GroupBox Header="{x:Static res:Strings.Common_Progress}" Margin="0,10,0,0">
                <TextBox Margin="6"
                         MinHeight="120"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Text="{Binding ProgressText}" />
            </GroupBox>
        </StackPanel>
    </ScrollViewer>
</UserControl>
