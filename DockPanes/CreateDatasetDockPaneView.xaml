<UserControl x:Class="ArcGisProAppYolo.DockPanes.CreateDatasetDockPaneView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="900"
             d:DesignWidth="450">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/ArcGIS.Desktop.Framework;component/Themes/Default.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

            <CollectionViewSource x:Key="EnabledPreviewOperationsView"
                                  Source="{Binding EnabledPreviewOperations}">
                <CollectionViewSource.GroupDescriptions>
                    <PropertyGroupDescription PropertyName="Category" />
                </CollectionViewSource.GroupDescriptions>
            </CollectionViewSource>

            <DataTemplate x:Key="AugmentationTemplate">
                <Border Margin="0,0,0,8" Padding="6" BorderBrush="#22000000" BorderThickness="1" CornerRadius="4">
                    <StackPanel>
                        <CheckBox Content="{Binding Name}" IsChecked="{Binding IsEnabled}" ToolTip="Включить/отключить аугментацию." />

                        <TextBlock Margin="0,4,0,0"
                                   Text="{Binding Description}"
                                   Foreground="#555"
                                   TextWrapping="Wrap" />
                        <TextBlock Margin="0,2,0,0"
                                   Text="{Binding Recommendation, StringFormat=Рекомендация: {0}}"
                                   Foreground="#2F6F9F"
                                   FontStyle="Italic"
                                   TextWrapping="Wrap" />

                        <Grid Margin="0,6,0,0" Visibility="{Binding ShowValueSlider, Converter={StaticResource BoolToVisibility}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="76" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="76" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="18" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Диапазон:" />
                            <TextBox Grid.Column="1"
                                     Margin="8,0,0,0"
                                     Text="{Binding ValueMinText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Нижняя граница диапазона." />
                            <Button Grid.Column="2" Margin="2,0,0,0" Padding="0" Content="-" Command="{Binding DecrementValueMinCommand}" ToolTip="Уменьшить нижний порог." />
                            <Button Grid.Column="3" Margin="2,0,0,0" Padding="0" Content="+" Command="{Binding IncrementValueMinCommand}" ToolTip="Увеличить нижний порог." />

                            <TextBox Grid.Column="5"
                                     Margin="8,0,0,0"
                                     Text="{Binding ValueMaxText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Верхняя граница диапазона." />
                            <Button Grid.Column="6" Margin="2,0,0,0" Padding="0" Content="-" Command="{Binding DecrementValueMaxCommand}" ToolTip="Уменьшить верхний порог." />
                            <Button Grid.Column="7" Margin="2,0,0,0" Padding="0" Content="+" Command="{Binding IncrementValueMaxCommand}" ToolTip="Увеличить верхний порог." />
                        </Grid>

                        <Grid Margin="0,4,0,0" Visibility="{Binding ShowProbabilitySlider, Converter={StaticResource BoolToVisibility}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="76" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Вероятность:" />
                            <TextBox Grid.Column="1"
                                     Margin="8,0,0,0"
                                     Text="{Binding ProbabilityText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Вероятность применения (0..1)." />
                            <Button Grid.Column="2" Margin="2,0,0,0" Padding="0" Content="-" Command="{Binding DecrementProbabilityCommand}" ToolTip="Уменьшить вероятность." />
                            <Button Grid.Column="3" Margin="2,0,0,0" Padding="0" Content="+" Command="{Binding IncrementProbabilityCommand}" ToolTip="Увеличить вероятность." />
                            <TextBlock Grid.Column="4"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="#666"
                                       Text="{Binding MinProbability, StringFormat=min: {0:0.##}}"
                                       ToolTip="Минимально допустимая вероятность." />
                            <TextBlock Grid.Column="5"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="#666"
                                       Text="{Binding MaxProbability, StringFormat=max: {0:0.##}}"
                                       ToolTip="Максимально допустимая вероятность." />
                        </Grid>

                        <Button Content="Reset"
                                Margin="0,6,0,0"
                                Width="90"
                                HorizontalAlignment="Left"
                                Command="{Binding DataContext.ResetAugmentationCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}"
                                ToolTip="Сброс к значениям по умолчанию." />
                    </StackPanel>
                </Border>
            </DataTemplate>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="10">
            <GroupBox Header="Ortho Selection" Margin="0,0,0,10">
                <StackPanel Margin="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0"
                                  ItemsSource="{Binding OrthoList}"
                                  SelectedItem="{Binding SelectedOrtho}"
                                  Margin="0,0,6,0"
                                  ToolTip="Выбор ОФП из текущего проекта ArcGIS Pro." />
                        <Button Grid.Column="1"
                                Content="⟳"
                                Width="28"
                                Height="28"
                                Command="{Binding RefreshOrthoListCommand}"
                                ToolTip="Обновить список ОФП." />
                    </Grid>
                    <TextBlock Margin="0,4,0,0" Foreground="Gray" Text="{Binding OrthoList.Count, StringFormat=Доступно: {0}}" />
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Annotation Layers" Margin="0,0,0,10">
                <StackPanel Margin="6">
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Text="Показываются только слои, в имени которых есть 'train'."
                                   TextWrapping="Wrap"
                                   Foreground="#555"
                                   ToolTip="Фильтр слоёв: имя слоя содержит train." />
                        <Button Grid.Column="1"
                                Content="⟳"
                                Width="28"
                                Height="28"
                                Margin="8,0,0,0"
                                Command="{Binding RefreshAnnotationLayersCommand}"
                                ToolTip="Обновить список (только слои с train в имени)." />
                    </Grid>

                    <Border BorderBrush="#22000000" BorderThickness="1" CornerRadius="4" Padding="6">
                        <ScrollViewer MaxHeight="120" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding AnnotationLayers}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}" Margin="0,0,0,4" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <TextBlock Margin="0,6,0,0" Foreground="#666" Text="{Binding SelectedAnnotationLayersSummary}" />
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Slicing Parameters" Margin="0,0,0,10">
                <StackPanel Margin="6">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Width="140" VerticalAlignment="Center" Text="Tile Size (px):" />
                        <TextBox Width="100" Text="{Binding TileSize, UpdateSourceTrigger=PropertyChanged}" ToolTip="Рекомендуемый диапазон 64..2048." />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Width="140" VerticalAlignment="Center" Text="Overlap (0..0.9):" />
                        <TextBox Width="100" Text="{Binding Overlap, UpdateSourceTrigger=PropertyChanged}" ToolTip="Например 0.2 = 20%." />
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Dataset Type" Margin="0,0,0,10">
                <StackPanel Margin="6">
                    <ComboBox Margin="0,6,0,0" ItemsSource="{Binding DatasetTypes}" SelectedItem="{Binding SelectedDatasetType}" ToolTip="Формат аннотаций в стиле Ultralytics YOLO." />
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Train / Val / Test Split" Margin="0,0,0,10">
                <StackPanel Margin="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="20" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Train:" />
                        <TextBox Grid.Column="1" Text="{Binding TrainPercent, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="%" />
                    </Grid>
                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="20" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Val:" />
                        <TextBox Grid.Column="1" Text="{Binding ValPercent, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="%" />
                    </Grid>
                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="20" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Test:" />
                        <TextBox Grid.Column="1" Text="{Binding TestPercent, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="%" />
                    </Grid>
                    <TextBlock Margin="0,6,0,0" Text="{Binding SplitSummary}" Foreground="#666" />
                    <TextBlock Margin="0,4,0,0" Text="{Binding SplitWarning}" Foreground="#c97b00" TextWrapping="Wrap" />
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Background / Class Balance / Debug" Margin="0,0,0,10">
                <StackPanel Margin="6">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Width="180" VerticalAlignment="Center" Text="Background limit:" />
                        <TextBox Width="70" Text="{Binding BackgroundLimit, UpdateSourceTrigger=PropertyChanged}" />
                        <CheckBox Margin="10,0,0,0" VerticalAlignment="Center" Content="Percent" IsChecked="{Binding BackgroundLimitIsPercent}" />
                    </StackPanel>

                    <CheckBox Content="Enable class balancing" IsChecked="{Binding EnableClassBalancing}" ToolTip="Балансировка классов для Train/Val." />
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock Width="180" VerticalAlignment="Center" Text="Balancing method:" />
                        <ComboBox Width="140" ItemsSource="{Binding BalanceMethods}" SelectedItem="{Binding SelectedBalanceMethod}" />
                    </StackPanel>

                    <CheckBox Margin="0,8,0,0" Content="Debug Mode" IsChecked="{Binding DebugMode}" ToolTip="Сохранять визуализации и доп. артефакты отладки." />
                </StackPanel>
            </GroupBox>

            <Expander Header="Data Augmentation" IsExpanded="{Binding IsAugmentationExpanded}" Margin="0,0,0,10">
                <StackPanel Margin="6">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock VerticalAlignment="Center" Text="Seed:" Width="60" />
                        <TextBox Width="120" Text="{Binding Seed, UpdateSourceTrigger=PropertyChanged}" ToolTip="Фиксированный seed для воспроизводимости." />
                        <CheckBox Margin="12,0,0,0"
                                  VerticalAlignment="Center"
                                  Content="Apply to Val"
                                  IsChecked="{Binding ApplyToVal}"
                                  ToolTip="Если включено: аугментация применяется также к split valid (валидация). Обычно оставляют выключенным, чтобы метрики отражали качество на 'чистых' данных." />
                        <CheckBox Margin="8,0,0,0"
                                  VerticalAlignment="Center"
                                  Content="Apply to Test"
                                  IsChecked="{Binding ApplyToTest}"
                                  ToolTip="Если включено: аугментация применяется также к split test. Рекомендуется выключать для объективного финального теста модели." />
                    </StackPanel>

                    <TabControl>
                        <TabItem Header="📐 Geometry">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding GeometryAugmentations}" ItemTemplate="{StaticResource AugmentationTemplate}" />
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="🎨 Color">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding ColorAugmentations}" ItemTemplate="{StaticResource AugmentationTemplate}" />
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="🌫️ Noise &amp; Blur">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding NoiseAugmentations}" ItemTemplate="{StaticResource AugmentationTemplate}" />
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="⚡ Advanced">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding AdvancedAugmentations}" ItemTemplate="{StaticResource AugmentationTemplate}" />
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="👁️ Preview">
                            <StackPanel Margin="6">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Width="120" VerticalAlignment="Center" Text="Tiles folder:" />
                                    <TextBox Width="220" Text="{Binding PreviewTilesFolder, UpdateSourceTrigger=PropertyChanged}" ToolTip="Путь к папке с тайлами для превью." />
                                    <Button Margin="8,0,0,0" Content="Browse" Command="{Binding BrowsePreviewTilesFolderCommand}" ToolTip="Выбрать папку с тайлами для превью." />
                                    <Button Margin="8,0,0,0"
                                            Content="Apply Next Transform"
                                            Command="{Binding ApplyRandomPreviewCommand}"
                                            ToolTip="Применить следующую трансформацию (по кругу) к текущему изображению." />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Width="120" VerticalAlignment="Center" Text="Apply selected:" />
                                    <ComboBox Width="220"
                                              ItemsSource="{Binding Source={StaticResource EnabledPreviewOperationsView}}"
                                              DisplayMemberPath="DisplayName"
                                              SelectedItem="{Binding SelectedPreviewOperation, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              ToolTip="Выберите включённую трансформацию, чтобы сразу применить её к текущему тайлу.">
                                        <ComboBox.GroupStyle>
                                            <GroupStyle>
                                                <GroupStyle.HeaderTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="#666" />
                                                    </DataTemplate>
                                                </GroupStyle.HeaderTemplate>
                                            </GroupStyle>
                                        </ComboBox.GroupStyle>
                                    </ComboBox>
                                  <TextBlock VerticalAlignment="Center"
                                           Foreground="#2F6F9F"
                                           FontStyle="Italic"
                                           Text="Applying transform..."
                                           Visibility="{Binding IsPreviewApplying, Converter={StaticResource BoolToVisibility}}" />
                                </StackPanel>

                                

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Width="120" VerticalAlignment="Center" Text="Current tile:" />
                                    <TextBox Width="220" Text="{Binding PreviewTile, UpdateSourceTrigger=PropertyChanged}" ToolTip="Текущий файл тайла для превью." />
                                    <Button Margin="8,0,0,0" Width="28" Content="←" Command="{Binding PreviewPrevImageCommand}" ToolTip="Предыдущее изображение" />
                                    <TextBlock Margin="8,0,8,0" Width="70" VerticalAlignment="Center" TextAlignment="Center" Text="{Binding PreviewImagePosition}" />
                                    <Button Width="28" Content="→" Command="{Binding PreviewNextImageCommand}" ToolTip="Следующее изображение" />
                                </StackPanel>

                                <TextBlock Margin="0,0,0,8"
                                           Foreground="#555"
                                           TextWrapping="Wrap"
                                           Text="Выберите папку с тайлами: загрузится первое изображение. Кнопками ←/→ переключайте изображения. По кнопке Apply Next Transform применяется одна следующая включённая трансформация." />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Margin="0,0,6,0" Height="180" BorderThickness="1" BorderBrush="#33000000" Background="#11000000">
                                        <Image Stretch="Uniform" Source="{Binding OriginalPreviewImagePath}" />
                                    </Border>
                                    <Border Grid.Column="1" Margin="6,0,0,0" Height="180" BorderThickness="1" BorderBrush="#33000000" Background="#11000000">
                                        <Image Stretch="Uniform" Source="{Binding AugmentedPreviewImagePath}" />
                                    </Border>
                                </Grid>

                                <TextBlock Margin="0,8,0,0" Text="Applied:" FontWeight="Bold" />
                                <TextBlock Text="{Binding PreviewAppliedTransforms}" TextWrapping="Wrap" />
                            </StackPanel>
                        </TabItem>

                        <TabItem Header="💾 Presets">
                            <StackPanel Margin="6">
                                <TextBlock Text="Built-in presets:" FontWeight="Bold" />
                                <TextBlock Margin="0,4,0,0"
                                           Foreground="#555"
                                           TextWrapping="Wrap"
                                           Text="Preset — это готовый набор включённых аугментаций, их диапазонов и вероятностей. Используйте как стартовую точку, затем подстраивайте под ваш датасет." />
                                <WrapPanel Margin="0,6,0,0">
                                    <Button Margin="0,0,6,6" Content="None" Command="{Binding ApplyPresetCommand}" CommandParameter="None" ToolTip="Отключить все аугментации и вернуть дефолтные значения." />
                                    <Button Margin="0,0,6,6" Content="Light" Command="{Binding ApplyPresetCommand}" CommandParameter="Light" ToolTip="Лёгкие и безопасные аугментации: минимальные геометрические/цветовые изменения." />
                                    <Button Margin="0,0,6,6" Content="Standard" Command="{Binding ApplyPresetCommand}" CommandParameter="Standard" ToolTip="Сбалансированный набор для большинства задач детекции/сегментации." />
                                    <Button Margin="0,0,6,6" Content="Aggressive" Command="{Binding ApplyPresetCommand}" CommandParameter="Aggressive" ToolTip="Максимально сильные аугментации. Используйте осторожно и проверяйте деградацию качества." />
                                    <Button Margin="0,0,6,6" Content="Outdoor Aerial" Command="{Binding ApplyPresetCommand}" CommandParameter="Outdoor Aerial" ToolTip="Набор под уличные/аэрофото сцены: тени, туман, локальный контраст." />
                                </WrapPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <Button Content="Save preset (.json)"
                                            Command="{Binding SavePresetCommand}"
                                            Margin="0,0,6,0"
                                            ToolTip="Сохранить текущие настройки аугментаций (включая диапазоны и вероятности) в JSON файл для повторного использования." />
                                    <Button Content="Load preset (.json)"
                                            Command="{Binding LoadPresetCommand}"
                                            ToolTip="Загрузить ранее сохранённый JSON preset и применить его к текущей панели." />
                                </StackPanel>

                                <Button Margin="0,8,0,0"
                                        Content="Export hyp.yaml"
                                        Command="{Binding ExportHypCommand}"
                                        Width="160"
                                        ToolTip="Экспорт параметров в формат hyp.yaml для Ultralytics YOLO (удобно для CLI-тренировок)." />
                            </StackPanel>
                        </TabItem>
                    </TabControl>

                    <GroupBox Header="Summary" Margin="0,10,0,0">
                        <StackPanel Margin="6">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Width="210" VerticalAlignment="Center" Text="Estimated source images:" />
                                <TextBox Width="100" Text="{Binding EstimatedSourceTiles, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <TextBlock Text="{Binding DatasetMultiplier, StringFormat=Dataset multiplier: ×{0}}" />
                            <TextBlock Margin="0,4,0,0" Text="{Binding EstimatedTotalAfterAugmentation, StringFormat=Estimated total images: {0}}" />
                            <TextBlock Margin="0,4,0,0" Text="{Binding EstimatedGenerationTime, StringFormat=Estimated generation time: {0}}" />
                            <TextBlock Margin="0,4,0,0" Foreground="#c97b00" TextWrapping="Wrap" Text="{Binding DatasetSizeWarning}" />
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </Expander>

            <TextBlock Margin="0,0,0,8" Foreground="#c97b00" TextWrapping="Wrap" Text="{Binding ValidationWarning}" />

            <Button Height="32"
                    Content="{Binding RunButtonText}"
                    Command="{Binding RunCreateDatasetCommand}"
                    IsEnabled="{Binding IsRunEnabled}"
                    ToolTip="Запустить формирование датасета." />

            <GroupBox Header="Progress" Margin="0,10,0,0">
                <TextBox Margin="6"
                         MinHeight="120"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Text="{Binding ProgressText}" />
            </GroupBox>
        </StackPanel>
    </ScrollViewer>
</UserControl>
