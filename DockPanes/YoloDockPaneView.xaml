<UserControl x:Class="ArcGisProAppYolo.DockPanes.YoloDockPaneView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="400">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/ArcGIS.Desktop.Framework;component/Themes/Default.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Project Info -->
        <!--<GroupBox Header="Project Information" Grid.Row="0" Margin="0,0,0,10">
            <StackPanel Margin="5">
                <TextBlock Text="Project URI:" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBlock Text="{Binding ProjectUri}" TextWrapping="Wrap" Margin="0,0,0,10"/>
            </StackPanel>
        </GroupBox>-->

        <!-- Ortho Selection -->
        <GroupBox Header="Ortho Selection" Grid.Row="1" Margin="0,0,0,10">
            <StackPanel Margin="5">
                <TextBlock Text="Select Ortho:" Margin="0,0,0,5" ToolTip="Выберите ортофотоплан для обработки."/>
                <Grid Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox ItemsSource="{Binding OrthoList}"
                              SelectedItem="{Binding SelectedOrtho}"
                              Grid.Column="0"
                              Margin="0,0,5,0"
                              ToolTip="Список доступных ортофотопланов проекта."/>
                    <Button Content="⟳"
                            Command="{Binding RefreshOrthoListCommand}"
                            Grid.Column="1"
                            Width="28"
                            Height="28"
                            ToolTip="Обновить список ортофото."/>
                </Grid>
                <TextBlock Text="{Binding OrthoList.Count, StringFormat='Available: {0} item(s)'}" 
                           FontStyle="Italic" 
                           Foreground="Gray"/>
            </StackPanel>
        </GroupBox>

        <!-- Model Path -->
        <GroupBox Header="Model Configuration" Grid.Row="2" Margin="0,0,0,10">
            <Grid Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0"
                          Margin="0,0,5,0"
                          IsEditable="False"
                          ItemsSource="{Binding KnownModels}"
                          DisplayMemberPath="DisplayName"
                          SelectedItem="{Binding SelectedKnownModel, Mode=TwoWay}"
                          ToolTip="{Binding ModelPath}">
                    <ComboBox.ItemContainerStyle>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="ToolTip" Value="{Binding FullPath}" />
                        </Style>
                    </ComboBox.ItemContainerStyle>
                </ComboBox>
                <Button Content="Browse..." 
                        Command="{Binding BrowseCommand}" 
                        Grid.Column="1" 
                        Width="80"
                        ToolTip="Выбрать файл модели (.pt/.onnx)."/>
            </Grid>
        </GroupBox>

        <!-- Tile Settings -->
        <GroupBox Header="Tile Settings" Grid.Row="3" Margin="0,0,0,10">
            <StackPanel Margin="5">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                    <TextBlock Text="Tile Size:" Width="100" VerticalAlignment="Center" ToolTip="Размер тайла в пикселях."/>
                    <TextBox Text="{Binding TileSize, UpdateSourceTrigger=PropertyChanged}" Width="80" ToolTip="Чем больше тайл, тем выше потребление памяти."/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Overlap (%):" Width="100" VerticalAlignment="Center" ToolTip="Перекрытие соседних тайлов в процентах."/>
                    <TextBox Text="{Binding OverlapPercent, UpdateSourceTrigger=PropertyChanged}" Width="80" ToolTip="Больше overlap уменьшает пропуски на границах."/>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <!-- Detection Settings -->
        <GroupBox Header="Detection Settings" Grid.Row="4" Margin="0,0,0,10">
            <StackPanel Margin="5">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                    <TextBlock Text="Confidence:" Width="100" VerticalAlignment="Center" ToolTip="Порог уверенности модели (0..1)."/>
                    <TextBox Text="{Binding Confidence, UpdateSourceTrigger=PropertyChanged}" Width="80" ToolTip="Ниже порога объекты отбрасываются."/>
                </StackPanel>
                <CheckBox Content="Output Points" IsChecked="{Binding OutputPoints}" Margin="0,5,0,0" ToolTip="Создать слой точек центров объектов."/>
                <CheckBox Content="Output Masks" IsChecked="{Binding OutputMasks}" Margin="0,5,0,0" ToolTip="Создать слой полигонов масок."/>
                <CheckBox Content="Output Boxes" IsChecked="{Binding OutputBBoxes}" Margin="0,5,0,0" ToolTip="Создать слой ограничивающих прямоугольников."/>
                <CheckBox Content="Output OBB" IsChecked="{Binding OutputOBB}" Margin="0,5,0,0" ToolTip="Создать слой ориентированных ограничивающих прямоугольников."/>
                <CheckBox Content="Use SAHI slicing" IsChecked="{Binding UseSahi}" Margin="0,5,0,0" ToolTip="Оставлено для совместимости; используется SAHI."/>

                <GroupBox Header="Mask Mode" Margin="0,8,0,0" ToolTip="Как формировать маску при нескольких контурах.">
                    <StackPanel Margin="5">
                        <RadioButton Content="Largest"
                                     IsChecked="{Binding MaskModeLargest}"
                                     Margin="0,0,0,4"
                                     ToolTip="Оставить только самый большой контур (1 маска = 1 объект)."/>
                        <RadioButton Content="Union"
                                     IsChecked="{Binding MaskModeUnion}"
                                     ToolTip="Объединить все контуры в одну геометрию."/>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </GroupBox>

        <!-- Run Button -->
        <Button Content="{Binding RunButtonText}" 
                Command="{Binding RunCommand}" 
                Grid.Row="5" 
                Height="30" 
                Margin="0,0,0,10"
                IsEnabled="{Binding IsRunEnabled}"
                ToolTip="Запуск детекции. Во время выполнения кнопка переключится в Cancel."/>

        <!-- Progress -->
        <GroupBox Header="Progress" Grid.Row="6" Margin="0,0,0,10">
            <TextBox Text="{Binding ProgressText}"
                     Margin="5"
                     MinHeight="120"
                     AcceptsReturn="True"
                     IsReadOnly="True"
                     TextWrapping="NoWrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     ToolTip="Полный построчный лог выполнения. Можно выделять и копировать."/>
        </GroupBox>

    </Grid>
</UserControl>

